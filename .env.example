# ── Paths ────────────────────────────────────────────────────────────────────
CV_LIBRARY_PATH=../cv-library

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite — embedded. File is created automatically on first run.
DB_PATH=./data/atat.db

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Model Parameters ──────────────────────────────────────────────────────────
TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=8192
THINKING_BUDGET=8000
ENABLE_CACHING=true

# ── Rendering ─────────────────────────────────────────────────────────────────
RENDER_PDF=true

# ── Pipeline Config ───────────────────────────────────────────────────────────
JDS_PATH=./jds
OUTPUT_PATH=./output
LOG_LEVEL=INFO
