# ── Paths ────────────────────────────────────────────────────────────────────
CV_LIBRARY_PATH=../cv-library

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: anthropic, openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Model Parameters ──────────────────────────────────────────────────────────
# Temperature: 0.3 recommended for factual accuracy against source library.
# Ignored when THINKING_BUDGET > 0 (API requires temperature=1 for thinking).
TEMPERATURE=0.3

# Max output tokens for the CV itself (not including thinking budget).
MAX_OUTPUT_TOKENS=8192

# Extended thinking budget in tokens (Anthropic only).
# Gives the model dedicated reasoning before writing the CV.
# Set to 0 to disable. Recommended range: 5000-10000.
THINKING_BUDGET=8000

# Prompt caching: cache the stable system prompt to reduce cost and latency.
ENABLE_CACHING=true

# ── Rendering ─────────────────────────────────────────────────────────────────
# Set to true to automatically render cv.md -> cv.pdf after generation.
# Set to false to produce Markdown only (review before committing to PDF).
RENDER_PDF=true

# ── Pipeline Config ───────────────────────────────────────────────────────────
JDS_PATH=./jds
OUTPUT_PATH=./output
LOG_LEVEL=INFO
