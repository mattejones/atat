# ── Demo mode ────────────────────────────────────────────────────────────────
# When true, CV library and DB paths are fixed to ./demo/ (convention-based).
# No additional path config is needed — set this flag and restart both servers.
# The UI banner is driven by the /settings API response — no frontend flag required.
DEMO_MODE=false

# ── Paths ────────────────────────────────────────────────────────────────────
# Ignored when DEMO_MODE=true.
CV_LIBRARY_PATH=../cv-library

# ── Database ───────────────────────────────────────────────────────────────────
# Ignored when DEMO_MODE=true (uses ./demo/atat.db instead).
DB_PATH=./data/atat.db

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Judge model — Tier 2 accuracy checks. Cheaper/faster than LLM_MODEL.
# Anthropic: claude-haiku-4-5-20251001
# OpenAI:    gpt-4o-mini
JUDGE_MODEL=claude-haiku-4-5-20251001

# Retry model — section-level rewrites during human-in-the-loop review.
# No thinking budget is applied. Defaults to JUDGE_MODEL if not set.
# Override to a mid-tier model (e.g. claude-sonnet-4-6) if retry quality is insufficient.
RETRY_MODEL=claude-haiku-4-5-20251001

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ── Model Parameters ──────────────────────────────────────────────────────────
TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=8192
THINKING_BUDGET=8000
ENABLE_CACHING=true

# ── Rendering ─────────────────────────────────────────────────────────────────
RENDER_PDF=true

# ── Scheduler / auto-ghost ────────────────────────────────────────────────────
# AUTO_GHOST_ENABLED        — set to false to disable the background ghost check entirely
# AUTO_GHOST_DAYS           — days of inactivity before an application is marked ghosted
#                             Eligible statuses: applied, acknowledged, interviewing, case_study
# SCHEDULER_INTERVAL_HOURS  — how often the ghost check runs (in hours)
AUTO_GHOST_ENABLED=true
AUTO_GHOST_DAYS=21
SCHEDULER_INTERVAL_HOURS=6

# ── Pipeline Config ───────────────────────────────────────────────────────────
JDS_PATH=./jds
OUTPUT_PATH=./output
LOG_LEVEL=INFO
